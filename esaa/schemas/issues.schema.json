{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://esaa.local/schemas/issues.schema.json",
  "title": "ESAA Issues Projection",
  "type": "object",
  "required": ["schema_version", "issues"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string", "const": "0.4.0"},
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_id", "status", "severity", "title"],
        "properties": {
          "issue_id": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["open", "resolved"]},
          "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
          "title": {"type": "string"},
          "task_id": {"type": "string"},
          "evidence": {"type": "object"},
          "reported_at": {"type": "string"},
          "resolved_at": {"type": ["string", "null"]},
          "resolved_by_task_id": {"type": ["string", "null"]}
        }
      }
    }
  }
}
